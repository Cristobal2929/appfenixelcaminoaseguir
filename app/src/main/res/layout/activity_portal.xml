<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teshua_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <Space android:layout_width="0dp" android:layout_height="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/portal_titulo"
            android:textColor="@color/teshua_dorado"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"/>

        <View
            android:layout_width="120dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/hilo_estandarte_doce"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/portal_intro"
            android:textColor="@color/teshua_texto"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/inputNombrePortal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/portal_hint_nombre"
            android:inputType="textPersonName|textCapWords"
            android:textColorHint="@color/teshua_texto_apagado"
            android:textColor="@color/teshua_texto"
            android:background="@color/teshua_fondo_panel"
            android:padding="14dp"/>

        <EditText
            android:id="@+id/inputApellidosPortal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/portal_hint_apellidos"
            android:inputType="textPersonName|textCapWords"
            android:textColorHint="@color/teshua_texto_apagado"
            android:textColor="@color/teshua_texto"
            android:background="@color/teshua_fondo_panel"
            android:padding="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/portal_fecha_label"
            android:textColor="@color/teshua_dorado_suave"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/inputFechaPortal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/portal_fecha_pulsa"
            android:textColor="@color/teshua_texto_apagado"
            android:background="@color/teshua_fondo_panel"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/portal_sexo_label"
            android:textColor="@color/teshua_dorado_suave"
            android:textSize="14sp"/>

        <RadioGroup
            android:id="@+id/grupoSexoPortal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioHijo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/portal_sexo_h"
                android:textColor="@color/teshua_texto"
                android:buttonTint="@color/teshua_dorado"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/radioHija"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="@string/portal_sexo_m"
                android:textColor="@color/teshua_texto"
                android:buttonTint="@color/teshua_dorado"/>
        </RadioGroup>

        <Button
            android:id="@+id/btnDescifrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/portal_boton_descifrar"
            android:backgroundTint="@color/teshua_dorado"
            android:textColor="@color/teshua_fondo"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/progressPortal"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/estadoPortal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/teshua_rojizo"
            android:textSize="13sp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
