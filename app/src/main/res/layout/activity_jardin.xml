<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teshua_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <Space android:layout_width="0dp" android:layout_height="40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/jardin_hub_titulo"
            android:textColor="@color/teshua_dorado"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <View
            android:layout_width="120dp"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/hilo_estandarte_doce"/>

        <TextView
            android:id="@+id/tvNombreJardin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="30dp"
            android:textColor="@color/teshua_texto_apagado"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/btnJardinTemplo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/jardin_boton_templo"
            android:backgroundTint="@color/teshua_dorado"
            android:textColor="@color/teshua_fondo"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnJardinAltar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/jardin_boton_altar"
            android:backgroundTint="@color/teshua_fondo_panel"
            android:textColor="@color/teshua_texto_apagado"/>

        <Button
            android:id="@+id/btnJardinRio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/jardin_boton_rio"
            android:backgroundTint="@color/teshua_fondo_panel"
            android:textColor="@color/teshua_texto_apagado"/>

        <Button
            android:id="@+id/btnJardinCirculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/jardin_boton_circulo"
            android:backgroundTint="@color/teshua_fondo_panel"
            android:textColor="@color/teshua_texto_apagado"/>

    </LinearLayout>
</ScrollView>
