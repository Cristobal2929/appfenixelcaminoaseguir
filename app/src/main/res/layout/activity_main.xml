<?xml version="1.0" encoding="utf-8"?>
<!--
    Fase Home (rediseño): pantalla principal 100% nativa.

    Antes esta pantalla era un WebView que mostraba el Space completo — eso
    exponía el Space de Pedro directamente al usuario. Ahora es una pantalla
    propia, con la identidad Teshuá (espiral dorada, letras hebreas, paleta
    negro/dorado), y un único camino hacia adelante: el botón "Hablar con
    Fénix", que abre ChatActivity (texto + voz, nativo, sin mostrar nunca
    el Space). El Space sigue siendo el cerebro detrás de cámaras, pero
    nadie lo ve ni lo abre.

    El emblema ya no es siempre la espiral genérica: MainActivity lo
    sustituye por el sello de la tribu de la persona (emblema_<id>, ver
    Tribu.kt) en cuanto hay una casa revelada en Prefs, junto con su nombre
    y un consejo propio de esa tribu para el día a día.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teshua_fondo">

    <!-- Letras hebreas decorativas, muy tenues, de fondo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="36dp"
        android:text="תשובה"
        android:textColor="#1FD4AF37"
        android:textSize="64sp"
        android:textStyle="bold"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="36dp">

        <FrameLayout
            android:id="@+id/emblema"
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:background="@drawable/bg_emblema_home">

            <ImageView
                android:id="@+id/ivEmblemaTribu"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_teshua_spiral"
                android:contentDescription="@string/app_name"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="@string/app_name"
            android:textColor="@color/teshua_dorado"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/splash_subtitulo"
            android:textColor="@color/teshua_texto_apagado"
            android:textSize="14sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvNombreTribuHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/teshua_dorado"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:gravity="center"
            android:visibility="gone"
            tools:text="Casa de Judá"/>

        <TextView
            android:id="@+id/tvBienvenidaHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/home_bienvenida"
            android:textColor="@color/teshua_texto"
            android:textSize="15sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="36dp"
        android:paddingBottom="48dp">

        <Button
            android:id="@+id/btnHablarFenix"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_boton_hablar"
            android:text="@string/home_boton_hablar"
            android:textAllCaps="false"
            android:textColor="@color/teshua_texto"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="4dp"/>

        <TextView
            android:id="@+id/btnAjustesHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:padding="8dp"
            android:text="@string/home_ajustes"
            android:textColor="@color/teshua_texto_apagado"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/btnBurbujaHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:text="@string/home_burbuja"
            android:textColor="@color/teshua_texto_apagado"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/btnJardinHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:text="@string/home_jardin"
            android:textColor="@color/teshua_dorado_suave"
            android:textSize="13sp"/>

    </LinearLayout>

</FrameLayout>
