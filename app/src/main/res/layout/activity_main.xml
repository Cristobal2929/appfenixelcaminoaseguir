<?xml version="1.0" encoding="utf-8"?>
<!--
    Fase A+B: layout limpio de la app principal.
    - webView ocupa toda la pantalla (carga el Space completo, con voz e IA).
    - fabTeshua es el botón flotante semi-transparente y arrastrable:
        toque corto -> abre ChatActivity (chat en vivo, texto).
        arrastrar hasta closeZone (abajo-centro) -> cierra la app.
    - closeZone solo se hace visible mientras se arrastra el botón.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teshua_fondo">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <TextView
        android:id="@+id/closeZone"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_close_zone"
        android:gravity="center"
        android:text="✕"
        android:textColor="@color/teshua_texto"
        android:textSize="26sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <FrameLayout
        android:id="@+id/fabTeshua"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="120dp"
        android:alpha="0.35"
        android:background="@drawable/bg_fab_teshua"
        android:elevation="12dp">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_teshua_spiral"
            android:contentDescription="@string/app_name"/>
    </FrameLayout>

</FrameLayout>
