<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teshua_fondo"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/btnVolverJardinAltar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/altar_volver"
        android:textColor="@color/teshua_dorado_suave"
        android:textSize="13sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/altar_titulo"
        android:textColor="@color/teshua_dorado"
        android:textSize="22sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="@string/altar_subtitulo"
        android:textColor="@color/teshua_texto_apagado"
        android:textSize="13sp"/>

    <EditText
        android:id="@+id/inputIntencion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minLines="2"
        android:gravity="top"
        android:hint="@string/altar_hint"
        android:textColorHint="@color/teshua_texto_apagado"
        android:textColor="@color/teshua_texto"
        android:background="@color/teshua_fondo_panel"
        android:padding="14dp"/>

    <Button
        android:id="@+id/btnEncenderLuz"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/altar_boton_encender"
        android:backgroundTint="@color/teshua_dorado"
        android:textColor="@color/teshua_fondo"
        android:textStyle="bold"/>

    <ProgressBar
        android:id="@+id/progressAltar"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/estadoAltar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/teshua_texto"
        android:textSize="13sp"
        android:visibility="gone"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/altar_historial_titulo"
        android:textColor="@color/teshua_dorado_suave"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/listaLuces"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

</LinearLayout>
