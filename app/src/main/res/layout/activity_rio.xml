<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teshua_fondo"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/btnVolverJardinRio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/rio_volver"
        android:textColor="@color/teshua_dorado_suave"
        android:textSize="13sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/rio_titulo"
        android:textColor="@color/teshua_dorado"
        android:textSize="22sp"
        android:textStyle="bold"/>

    <View
        android:layout_width="72dp"
        android:layout_height="4dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/hilo_juda"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="@string/rio_subtitulo"
        android:textColor="@color/teshua_texto_apagado"
        android:textSize="13sp"/>

    <ScrollView
        android:id="@+id/scrollRio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/contenedorChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

    <ProgressBar
        android:id="@+id/progressRio"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/estadoRio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/teshua_texto_apagado"
        android:textSize="12sp"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/inputMensajeRio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minLines="1"
            android:maxLines="4"
            android:gravity="top"
            android:hint="@string/rio_hint"
            android:textColorHint="@color/teshua_texto_apagado"
            android:textColor="@color/teshua_texto"
            android:background="@color/teshua_fondo_panel"
            android:padding="14dp"/>

        <Button
            android:id="@+id/btnEnviarRio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/rio_boton_enviar"
            android:backgroundTint="@color/teshua_dorado"
            android:textColor="@color/teshua_fondo"
            android:textStyle="bold"/>

    </LinearLayout>

</LinearLayout>
